# Shared local environment template.
# Copy values into service-specific local env files; never commit real secrets.

# Web
NEXT_PUBLIC_APP_ENV=local
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_publishable_or_anon_key

# API
EQAR_ENVIRONMENT=local
EQAR_CORS_ORIGINS=http://localhost:3000
EQAR_AUTH_DISABLED=true
EQAR_SUPABASE_URL=https://your-project-ref.supabase.co
EQAR_SUPABASE_ANON_KEY=your_publishable_or_anon_key
EQAR_SUPABASE_SERVICE_ROLE_KEY=your_secret_or_service_role_key
EQAR_SUPABASE_JWT_SECRET=your_jwt_secret
EQAR_SUPABASE_JWT_AUDIENCE=authenticated
EQAR_OPENAI_API_KEY=
EQAR_OPENAI_MODEL=gpt-4.1-mini
EQAR_OPENAI_EMBEDDING_MODEL=text-embedding-3-small
EQAR_REDIS_URL=redis://localhost:6379/0

{
  "name": "eqar",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/web",
    "packages/shared"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @eqar/web",
    "dev:web": "npm run dev --workspace @eqar/web",
    "build:web": "npm run build --workspace @eqar/web",
    "lint:web": "npm run lint --workspace @eqar/web",
    "typecheck": "npm run typecheck --workspace @eqar/shared && npm run typecheck --workspace @eqar/web",
    "test:api": "cd apps/api && ..\\..\\.venv\\Scripts\\python.exe -m pytest",
    "lint:api": "cd apps/api && ..\\..\\.venv\\Scripts\\python.exe -m ruff check .",
    "format:api": "cd apps/api && ..\\..\\.venv\\Scripts\\python.exe -m ruff format ."
  },
  "overrides": {
    "postcss@8.4.31": "8.5.10"
  },
  "devDependencies": {
    "typescript": "^5.5.4"
  }
}
